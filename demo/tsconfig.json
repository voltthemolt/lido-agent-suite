{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "viem": ["../mcp-server/node_modules/viem"],
      "viem/*": ["../mcp-server/node_modules/viem/*"]
    },
    "baseUrl": "."
  },
  "include": ["*.ts"]
}
