    {"type": "text", "id": "title", "x": 100, "y": 20, "width": 400, "height": 35, "text": "Agent Treasury Lifecycle", "fontSize": 28, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center"},

    {"type": "rectangle", "id": "step1", "x": 50, "y": 80, "width": 180, "height": 80, "roundness": {"type": 3}, "backgroundColor": "#a5d8ff", "fillStyle": "solid", "boundElements": [{"id": "t_step1", "type": "text"}, {"id": "t_step1_sub", "type": "text"}]},
    {"type": "text", "id": "t_step1", "x": 55, "y": 95, "width": 170, "height": 25, "text": "1. DEPOSIT", "fontSize": 18, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "step1", "originalText": "1. DEPOSIT", "autoResize": true},
    {"type": "text", "id": "t_step1_sub", "x": 55, "y": 122, "width": 170, "height": 20, "text": "Agent deposits stETH", "fontSize": 14, "fontFamily": 1, "strokeColor": "#495057", "textAlign": "center", "verticalAlign": "middle", "containerId": "step1", "originalText": "Agent deposits stETH", "autoResize": true},

