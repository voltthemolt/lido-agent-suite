    {"type": "arrow", "id": "a2", "x": 460, "y": 120, "width": 50, "height": 0, "points": [[0,0],[50,0]], "endArrowhead": "arrow", "strokeColor": "#1971c2", "startBinding": {"elementId": "step2", "fixedPoint": [1, 0.5]}, "endBinding": {"elementId": "step3", "fixedPoint": [0, 0.5]}},

    {"type": "rectangle", "id": "step4", "x": 280, "y": 220, "width": 180, "height": 80, "roundness": {"type": 3}, "backgroundColor": "#b2f2bb", "fillStyle": "solid", "boundElements": [{"id": "t_step4", "type": "text"}, {"id": "t_step4_sub", "type": "text"}]},
    {"type": "text", "id": "t_step4", "x": 285, "y": 235, "width": 170, "height": 25, "text": "4. SPEND", "fontSize": 18, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "step4", "originalText": "4. SPEND", "autoResize": true},
