    {"type": "arrow", "id": "a4", "x": 230, "y": 260, "width": 50, "height": 0, "points": [[0,0],[50,0]], "endArrowhead": "arrow", "strokeColor": "#1971c2", "startBinding": {"elementId": "step5", "fixedPoint": [1, 0.5]}, "endBinding": {"elementId": "step4", "fixedPoint": [0, 0.5]}},

