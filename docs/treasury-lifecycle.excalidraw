    {"type": "rectangle", "id": "step3", "x": 510, "y": 80, "width": 180, "height": 80, "roundness": {"type": 3}, "backgroundColor": "#c3fae8", "fillStyle": "solid", "boundElements": [{"id": "t_step3", "type": "text"}, {"id": "t_step3_sub", "type": "text"}]},
