    {"type": "arrow", "id": "a5", "x": 460, "y": 260, "width": 50, "height": 0, "points": [[0,0],[50,0]], "endArrowhead": "arrow", "strokeColor": "#1971c2", "startBinding": {"elementId": "step4", "fixedPoint": [1, 0.5]}, "endBinding": {"elementId": "step6", "fixedPoint": [0, 0.5]}},

    {"type": "text", "id": "note1", "x": 50, "y": 340, "width": 640, "height": 80, "text": "KEY INSIGHT: Principal is locked forever (or until withdrawal request completes).\nYield accumulates automatically as stETH rebases.\nAgent can only SPEND the yield - principal remains protected.\nThis enables autonomous agents to operate sustainably without draining funds.", "fontSize": 16, "fontFamily": 1, "strokeColor": "#495057", "textAlign": "center"}
